# ============================================================================
# SnapCal — environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and fill in real values.
# The demo runs end-to-end with USE_MOCKS=true and NO real keys at all —
# every external dependency has a mock adapter behind the same interface.
# When you receive Swiggy Builders Club credentials (and/or want real GPT-4o
# / Claude calls), flip USE_MOCKS=false and provide the relevant keys.
# ============================================================================

# ---------- Master mock switch ----------
# true  = use deterministic mocks for Vision AI, recipe engine, Swiggy MCP
# false = use real OpenAI / Anthropic / Swiggy MCP (requires keys below)
USE_MOCKS=true

# ---------- LLM / Vision providers ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---------- Supabase (optional — SQLite is the demo default) ----------
# When you set these, the repo layer can swap from SQLite to Supabase
# without code changes (single adapter swap).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ---------- Swiggy MCP (Builders Club) ----------
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=
SWIGGY_REDIRECT_URI=http://localhost:8000/api/swiggy/callback
SWIGGY_MCP_BASE_URL=

# ---------- App-level limits / guardrails ----------
DAILY_SNAP_LIMIT=50
CART_CAP_INR=1000

# ---------- Storage / runtime ----------
DB_URL=sqlite:///./snapcal.db
LOG_LEVEL=INFO

# ---------- Expo client (read by the React Native app) ----------
# Set this to your laptop's LAN IP when testing on a real phone:
#   e.g. EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
